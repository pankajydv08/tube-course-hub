# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=YourApp

# JWT Secret for authentication (use a strong, random string in production)
JWT_SECRET=your-super-secret-jwt-key-here

# Nebius API Key
VITE_NEBIUS_API_KEY=your-nebius-api-key-here

# Server port (optional, defaults to 5000)
PORT=5000